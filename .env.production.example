# HomeX — Environment Variables for Production
# Set these in Railway dashboard → Variables tab

MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster.mongodb.net/homex
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
NODE_ENV=production
PORT=5000
# For Railway-only deploy: CLIENT_ORIGIN=*
# For Vercel frontend + Railway backend:
# CLIENT_ORIGIN=https://your-app.vercel.app,https://your-app.up.railway.app
CLIENT_ORIGIN=*
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=100
